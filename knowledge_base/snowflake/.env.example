# ═══════════════════════════════════════════════════════════════════
# DataPilot Configuration
# cp .env.example .env  then fill in your values
# Only configure the databases you are actually using
# ═══════════════════════════════════════════════════════════════════

# ── Server ──────────────────────────────────────────────────────────
DATAPILOT_HOST=0.0.0.0
DATAPILOT_PORT=8001
DATAPILOT_DEBUG=false

# ── LLM — Ollama (local, air-gapped) ─────────────────────────────────
DATAPILOT_OLLAMA_BASE_URL=http://localhost:11434

# SQL generation model — stays resident in VRAM (keep_alive=-1)
# Options: qwen2.5-coder:7b-instruct-q4_0  or  deepseek-coder-v2:16b-q4_0
DATAPILOT_LLM_MODEL_PRIMARY=qwen2.5-coder:7b-instruct-q4_0
DATAPILOT_LLM_MODEL_FALLBACK=qwen2.5-coder:7b-instruct-q4_0

# KB generation model — loads and unloads after each generation (keep_alive=0)
DATAPILOT_LLM_MODEL_INTERVIEW=llama3.1:8b-instruct-q4_0

# Routing: true = auto-route complex queries to primary model
DATAPILOT_LLM_AUTO_ROUTE=false
# NEVER change temperature — deterministic SQL requires 0.0
DATAPILOT_LLM_TEMPERATURE=0.0
# Increase if KB generation times out on large schemas (15+ tables)
DATAPILOT_LLM_TIMEOUT_SECONDS=300
DATAPILOT_LLM_MAX_TOKENS=1024

# ── Knowledge Base ───────────────────────────────────────────────────
# Directory where generated .md KB files are stored
DATAPILOT_KNOWLEDGE_STORE_PATH=./knowledge_store

# ── Schema Introspection ─────────────────────────────────────────────
DATAPILOT_DB_QUERY_TIMEOUT=30
DATAPILOT_MAX_RESULT_ROWS=10000
DATAPILOT_INCLUDE_SAMPLE_VALUES=true
DATAPILOT_SAMPLE_VALUE_LIMIT=8
DATAPILOT_SCHEMA_CACHE_TTL=3600

# ── PostgreSQL ───────────────────────────────────────────────────────
# Comment out all PG_ lines if not using PostgreSQL
DATAPILOT_PG_HOST=localhost
DATAPILOT_PG_PORT=5432
DATAPILOT_PG_USER=your_pg_user
DATAPILOT_PG_PASSWORD=your_pg_password
DATAPILOT_PG_DATABASE=your_database
DATAPILOT_PG_SCHEMA=public
DATAPILOT_PG_SSL_MODE=prefer
DATAPILOT_PG_POOL_MIN=2
DATAPILOT_PG_POOL_MAX=10

# ── Azure SQL ─────────────────────────────────────────────────────────
# Comment out all AZ_ lines if not using Azure SQL
DATAPILOT_AZ_SERVER=yourserver.database.windows.net
DATAPILOT_AZ_PORT=1433
DATAPILOT_AZ_USER=your_az_user
DATAPILOT_AZ_PASSWORD=your_az_password
DATAPILOT_AZ_DATABASE=your_database
DATAPILOT_AZ_SCHEMA=dbo
DATAPILOT_AZ_DRIVER=ODBC Driver 18 for SQL Server
DATAPILOT_AZ_ENCRYPT=true
DATAPILOT_AZ_TRUST_SERVER_CERT=false
DATAPILOT_AZ_POOL_MIN=2
DATAPILOT_AZ_POOL_MAX=10

# ── Snowflake ─────────────────────────────────────────────────────────
# Comment out all SF_ lines if not using Snowflake
#
# SF_ACCOUNT: the part of your URL before .snowflakecomputing.com
#   URL format:  https://<orgname>-<accountname>.snowflakecomputing.com
#   Example URL: https://qnuxjnx-ba64697.snowflakecomputing.com
#   SF_ACCOUNT:  qnuxjnx-ba64697
#
DATAPILOT_SF_ACCOUNT=qnuxjnx-ba64697
DATAPILOT_SF_USER=sudsn
DATAPILOT_SF_PASSWORD=Sutharsan99#11
DATAPILOT_SF_DATABASE=COMPOUNDING_PHARMACY_DW
DATAPILOT_SF_SCHEMA=PHARMACY
DATAPILOT_SF_WAREHOUSE=COMPUTE_WH
# Role is optional — leave blank to use your user's default role
DATAPILOT_SF_ROLE=ACCOUNTADMIN
